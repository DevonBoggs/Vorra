{
  "name": "vorra",
  "version": "8.1.0",
  "description": "AI-powered study & life planner for managing courses, goals, habits, and focus sessions",
  "author": "Devon Boggs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DevonBoggs/Vorra"
  },
  "homepage": "https://github.com/DevonBoggs/Vorra#readme",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env ELECTRON_DEV=1 electron .\"",
    "electron:build": "vite build && electron-builder",
    "start": "electron .",
    "setup": "node scripts/setup.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "electron-rebuild || echo 'electron-rebuild skipped (non-critical)'"
  },
  "build": {
    "appId": "com.vorra.app",
    "productName": "Vorra",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "DevonBoggs",
      "repo": "Vorra"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "shortcutName": "Vorra",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*",
      "node_modules/prebuild-install/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "better-sqlite3": "^12.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.1",
    "tinykeys": "^3.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.1.2",
    "cross-env": "^10.1.0",
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
    "jsdom": "^29.0.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^4.1.0",
    "wait-on": "^8.0.3"
  },
  "overrides": {
    "tar": "^7.5.11",
    "@tootallnate/once": "^3.0.1",
    "semver": "^7.6.3",
    "ip": "^2.0.1",
    "braces": "^3.0.3",
    "micromatch": "^4.0.8",
    "got": "^12.6.1"
  }
}
